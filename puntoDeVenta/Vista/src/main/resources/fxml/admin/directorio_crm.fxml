<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.empresa.pos.controlador.admin.CRMController"
      spacing="20">

    <HBox alignment="CENTER_LEFT">
        <Label text="Directorio CRM" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        <Button text="+ Nuevo Cliente" styleClass="btn-success" onAction="#handleNuevoCliente"/>
    </HBox>

    <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
        <TableView fx:id="tblClientes" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId"     text="ID"                  prefWidth="70"/>
                <TableColumn fx:id="colNombre" text="Nombre / Razon Social" prefWidth="230"/>
                <TableColumn fx:id="colRfc"    text="RFC"                 prefWidth="140"/>
                <TableColumn fx:id="colTipo"   text="Tipo"                prefWidth="150"/>
                <TableColumn fx:id="colPuntos" text="Puntos Acumulados"   prefWidth="140"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
