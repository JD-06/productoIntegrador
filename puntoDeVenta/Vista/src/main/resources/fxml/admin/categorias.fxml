<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.empresa.pos.controlador.admin.CategoriasController"
      spacing="20">

    <Label text="Categorias" styleClass="page-title"/>

    <VBox styleClass="card" spacing="12">
        <Label text="Nueva categoria" style="-fx-font-weight: bold;"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="txtNuevaCategoria" promptText="Nombre de nueva categoria..."
                       HBox.hgrow="ALWAYS" style="-fx-font-size: 14px;"/>
            <Button text="+ Agregar" styleClass="btn-primary" onAction="#handleAgregar"/>
        </HBox>
    </VBox>

    <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
        <Label text="Categorias registradas" style="-fx-font-weight: bold;"/>
        <ListView fx:id="listCategorias" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px;"/>
    </VBox>
</VBox>
