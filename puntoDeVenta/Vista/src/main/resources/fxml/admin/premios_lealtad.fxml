<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.empresa.pos.controlador.admin.PremiosLealtadController"
      spacing="16">

    <Label text="Premios y Lealtad" styleClass="page-title"/>

    <!-- KPIs -->
    <HBox spacing="16">
        <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
            <Label text="Clientes con Puntos" styleClass="kpi-label"/>
            <Label fx:id="lblClientesPuntos" text="0" styleClass="kpi-value"/>
        </VBox>
        <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
            <Label text="Total Puntos Acumulados" styleClass="kpi-label"/>
            <Label fx:id="lblTotalPuntos" text="0" styleClass="kpi-value"/>
        </VBox>
    </HBox>

    <!-- Tabla de clientes con puntos -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="0">
        <TableView fx:id="tblClientes" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colPremCliente"  text="Cliente"  prefWidth="220"/>
                <TableColumn fx:id="colPremTipo"     text="Tipo"     prefWidth="110"/>
                <TableColumn fx:id="colPremPuntos"   text="Puntos"   prefWidth="100"/>
                <TableColumn fx:id="colPremAcciones" text="Acciones" prefWidth="100"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
