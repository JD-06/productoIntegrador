<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.empresa.pos.controlador.POSController"
            stylesheets="@../css/design-system.css">

    <!-- BARRA SUPERIOR -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="20">
            <Label text="POS ERP" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px;"/>
            <Separator orientation="VERTICAL"/>
            <Label fx:id="lblUsuario" text="Cajero" style="-fx-text-fill: white;"/>
            <Label fx:id="lblTurno"   text="Turno: --" style="-fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblStatus" text="" style="-fx-text-fill: #F5A623; -fx-font-size: 12px;"/>
            <Button text="Cerrar Turno" style="-fx-background-color: #C62828; -fx-text-fill: white;"
                    onAction="#handleCerrarTurno"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="10">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

            <!-- ZONA IZQUIERDA: CARRITO (55%) -->
            <VBox HBox.hgrow="ALWAYS" spacing="8" styleClass="card">

                <!-- Búsqueda rápida por SKU -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="txtBusqueda" promptText="Escanear codigo / SKU (F5)"
                               HBox.hgrow="ALWAYS" style="-fx-font-size: 15px;"/>
                </HBox>

                <!-- Tabla del carrito -->
                <TableView fx:id="tblCarrito" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colProducto" text="Producto"  prefWidth="220"/>
                        <TableColumn fx:id="colCantidad" text="Cant."     prefWidth="70"/>
                        <TableColumn fx:id="colPrecio"   text="Precio"    prefWidth="100"/>
                        <TableColumn fx:id="colSubtotal" text="Subtotal"  prefWidth="110"/>
                        <TableColumn fx:id="colAccion"   text=""          prefWidth="40"/>
                    </columns>
                    <placeholder><Label text="Carrito vacío — selecciona un producto"/></placeholder>
                </TableView>

                <!-- Totales -->
                <VBox spacing="4">
                    <HBox alignment="CENTER_RIGHT" spacing="20">
                        <Label text="SUBTOTAL:" style="-fx-font-size: 15px;"/>
                        <Label fx:id="lblSubtotal" text="0.00"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-min-width: 100; -fx-alignment: CENTER_RIGHT;"/>
                    </HBox>
                    <HBox alignment="CENTER_RIGHT" spacing="20">
                        <Label text="IVA (16%):" style="-fx-font-size: 15px;"/>
                        <Label fx:id="lblIva" text="0.00"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-min-width: 100; -fx-alignment: CENTER_RIGHT;"/>
                    </HBox>
                    <HBox alignment="CENTER_RIGHT" spacing="20">
                        <Label text="TOTAL:" styleClass="text-header"/>
                        <Label fx:id="lblTotal" text="0.00" styleClass="text-total"
                               style="-fx-min-width: 120; -fx-alignment: CENTER_RIGHT;"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- ZONA DERECHA: CATÁLOGO (45%) -->
            <VBox prefWidth="460" spacing="8">

                <!-- Filtros -->
                <HBox spacing="6">
                    <TextField fx:id="txtBusquedaProducto" promptText="Buscar producto..."
                               HBox.hgrow="ALWAYS" style="-fx-font-size: 13px;"/>
                    <ComboBox fx:id="cmbCategoriaPos" prefWidth="160"/>
                </HBox>

                <!-- Grid de productos -->
                <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" hbarPolicy="NEVER"
                            style="-fx-background: #F5F5F5; -fx-background-color: #F5F5F5;">
                    <FlowPane fx:id="flowProductos" hgap="8" vgap="8" prefWrapLength="444"
                              style="-fx-padding: 4;"/>
                </ScrollPane>

                <!-- Acciones del carrito -->
                <HBox spacing="6">
                    <Button text="Quitar [F11]" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #C62828; -fx-text-fill: white; -fx-padding: 8;"
                            onAction="#handleEliminarItem"/>
                    <Button text="Cancelar venta" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #757575; -fx-text-fill: white; -fx-padding: 8;"
                            onAction="#handleCancelarVenta"/>
                </HBox>
            </VBox>
        </HBox>
    </center>

    <!-- BARRA INFERIOR -->
    <bottom>
        <HBox styleClass="card" spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 8 16;">
            <Button text="Cajon [F4]" styleClass="btn-primary" onAction="#handleCajon"/>
            <Label fx:id="lblItemsCarrito" text="0 items" style="-fx-text-fill: #757575;"/>
            <Button text="Exportar CSV" styleClass="btn-primary" onAction="#handleExportarCsv"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="COBRAR [F12]" styleClass="btn-accent" prefWidth="280"
                    onAction="#handleCobrar"/>
        </HBox>
    </bottom>
</BorderPane>
