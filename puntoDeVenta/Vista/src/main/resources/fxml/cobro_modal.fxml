<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.empresa.pos.controlador.CobroController"
      spacing="20" prefWidth="440"
      style="-fx-background-color: #F5F5F5; -fx-padding: 30;">

    <Label text="COBRAR" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1A2D5A;"/>

    <!-- Total -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 6;">
        <Label text="Total a cobrar:" style="-fx-font-size: 15px; -fx-text-fill: #757575;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblTotalCobro" text="0.00"
               style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1A2D5A;"/>
    </HBox>

    <Separator/>

    <!-- Metodo de pago -->
    <VBox spacing="8">
        <Label text="Metodo de pago:" style="-fx-font-weight: bold;"/>
        <HBox spacing="10">
            <ToggleButton fx:id="btnEfectivo" text="Efectivo" maxWidth="Infinity"
                          HBox.hgrow="ALWAYS" onAction="#handleMetodoPago"
                          style="-fx-font-size: 14px;"/>
            <ToggleButton fx:id="btnTarjeta" text="Tarjeta" maxWidth="Infinity"
                          HBox.hgrow="ALWAYS" onAction="#handleMetodoPago"
                          style="-fx-font-size: 14px;"/>
        </HBox>
    </VBox>

    <!-- Panel efectivo -->
    <VBox fx:id="panelEfectivo" spacing="10">
        <Label text="Monto recibido:" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtMonto" promptText="0.00"
                   style="-fx-font-size: 22px; -fx-padding: 10;"/>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 6;">
            <Label text="Cambio:" style="-fx-font-size: 15px; -fx-text-fill: #757575;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblCambio" text="0.00"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
        </HBox>
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- Botones -->
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#handleCancelar"
                style="-fx-background-color: #757575; -fx-text-fill: white;
                       -fx-padding: 10 24; -fx-font-size: 13px;"/>
        <Button text="CONFIRMAR PAGO [Enter]" styleClass="btn-accent"
                onAction="#handleConfirmar"/>
    </HBox>
</VBox>
