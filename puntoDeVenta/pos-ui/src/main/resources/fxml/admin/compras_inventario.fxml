<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.empresa.pos.controller.admin.ComprasInventarioController"
      spacing="16">

    <Label text="Compras e Inventario" styleClass="page-title"/>

    <TabPane fx:id="tabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

        <!-- TAB 1: Inventario -->
        <Tab text="Inventario">
            <VBox spacing="10" style="-fx-padding: 12;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Modificar Stock" styleClass="btn-primary" onAction="#handleModificarStock"/>
                </HBox>
                <TableView fx:id="tblInventario" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colInvSku"      text="SKU"           prefWidth="100"/>
                        <TableColumn fx:id="colInvNombre"   text="Producto"      prefWidth="220"/>
                        <TableColumn fx:id="colInvActual"   text="Stock Actual"  prefWidth="110"/>
                        <TableColumn fx:id="colInvMinimo"   text="Stock Minimo"  prefWidth="110"/>
                        <TableColumn fx:id="colInvEstado"   text="Estado"        prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <!-- TAB 2: Compras -->
        <Tab text="Compras">
            <VBox spacing="10" style="-fx-padding: 12;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="+ Nueva Compra" styleClass="btn-success" onAction="#handleNuevaCompra"/>
                </HBox>
                <TableView fx:id="tblCompras" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colCmpId"        text="ID"          prefWidth="60"/>
                        <TableColumn fx:id="colCmpProveedor" text="Proveedor"   prefWidth="200"/>
                        <TableColumn fx:id="colCmpTotal"     text="Total"       prefWidth="110"/>
                        <TableColumn fx:id="colCmpFecha"     text="Fecha"       prefWidth="130"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>
    </TabPane>
</VBox>
