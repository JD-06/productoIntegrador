<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.empresa.pos.controller.admin.CxCController"
      spacing="16">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Cuentas por Cobrar" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        <Button text="+ Nueva CxC" styleClass="btn-success" onAction="#handleNuevaCxC"/>
    </HBox>

    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="0">
        <TableView fx:id="tblCxC" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCxcId"          text="ID"          prefWidth="60"/>
                <TableColumn fx:id="colCxcCliente"     text="Cliente"     prefWidth="200"/>
                <TableColumn fx:id="colCxcMonto"       text="Monto"       prefWidth="100"/>
                <TableColumn fx:id="colCxcSaldo"       text="Saldo"       prefWidth="100"/>
                <TableColumn fx:id="colCxcEstado"      text="Estado"      prefWidth="90"/>
                <TableColumn fx:id="colCxcVencimiento" text="Vencimiento" prefWidth="120"/>
                <TableColumn fx:id="colCxcAcciones"    text="Acciones"    prefWidth="90"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
