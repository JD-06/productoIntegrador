<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.empresa.pos.controller.admin.UsuariosController"
      spacing="20">

    <HBox alignment="CENTER_LEFT">
        <Label text="Gestion de Usuarios" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        <Button text="+ Nuevo Usuario" styleClass="btn-success" onAction="#handleNuevoUsuario"/>
    </HBox>

    <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
        <TableView fx:id="tblUsuarios" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId"     text="ID"     prefWidth="60"/>
                <TableColumn fx:id="colNombre" text="Nombre" prefWidth="200"/>
                <TableColumn fx:id="colRol"    text="Rol"    prefWidth="130"/>
                <TableColumn fx:id="colActivo" text="Estado" prefWidth="100"/>
                <TableColumn fx:id="colAccion" text="Acciones" prefWidth="200"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
