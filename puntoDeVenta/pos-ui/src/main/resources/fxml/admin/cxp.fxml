<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.empresa.pos.controller.admin.CxPController"
      spacing="16">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Cuentas por Pagar" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        <Button text="+ Nueva CxP" styleClass="btn-success" onAction="#handleNuevaCxP"/>
    </HBox>

    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="0">
        <TableView fx:id="tblCxP" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCxpId"          text="ID"          prefWidth="60"/>
                <TableColumn fx:id="colCxpProveedor"   text="Proveedor"   prefWidth="200"/>
                <TableColumn fx:id="colCxpMonto"       text="Monto"       prefWidth="100"/>
                <TableColumn fx:id="colCxpSaldo"       text="Saldo"       prefWidth="100"/>
                <TableColumn fx:id="colCxpEstado"      text="Estado"      prefWidth="90"/>
                <TableColumn fx:id="colCxpVencimiento" text="Vencimiento" prefWidth="120"/>
                <TableColumn fx:id="colCxpAcciones"    text="Acciones"    prefWidth="90"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
